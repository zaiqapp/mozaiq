generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Dashboard {
  id          String   @id
  name        String   @default("Untitled Dashboard")
  description String?
  layout      Json
  widgets     Json
  isPublic    Boolean  @default(true)
  views       Int      @default(0)
  userId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GenerationLog {
  id          String   @id @default(cuid())
  prompt      String
  success     Boolean
  widgetCount Int?
  ip          String?
  userId      String?
  createdAt   DateTime @default(now())
}
